# 复制为 .env 并填写
DEBUG=true
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/builddify
REDIS_URL=redis://localhost:6379/0
JWT_SECRET=change-me-to-a-32+byte-random-string

# ---- LLM ----
# 默认上游 provider:anthropic | openai
LLM_PROVIDER=anthropic

# Anthropic(Claude)。base_url 留空用官方;填则对接 Anthropic 兼容网关(如讯飞 /anthropic)
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# OpenAI / OpenAI 兼容(改 base_url 接 DeepSeek、vLLM、Ollama、讯飞 /v2 等)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_DEFAULT_MODEL=gpt-4o-mini

# embedding(走 OpenAI 兼容端点;Anthropic 无原生 embedding)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=768            # 须与 kb_segment.embedding 列宽一致(改了要重建迁移)

# ---- Agent ----
AGENT_MAX_ITERATIONS=6      # ReAct 单回合最大推理步数(防工具调用死循环)
